APP_NAME=Acolhe API
ENVIRONMENT=development
DEBUG=false

# Backend
DATABASE_URL=sqlite:///./acolhe.db
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
SEED_DEMO_DATA=true
RATE_LIMIT_PER_MINUTE=45
PRIMARY_USER_NAME=Usuaria Acolhe
PRIMARY_USER_PIN=2468

# LLM
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20

# Mobile
# Exemplo de execucao:
# flutter run --dart-define=API_BASE_URL=http://10.0.2.2:8000
# Para Docker/PostgreSQL, o docker-compose ja sobrescreve DATABASE_URL internamente.
